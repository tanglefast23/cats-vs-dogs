{
  "name": "cats-vs-dogs-backyard-battle",
  "productName": "Cats vs Dogs Backyard Battle",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k --success first \"vite\" \"wait-on tcp:127.0.0.1:4173 && electron . --dev\"",
    "electron": "npm run build && electron .",
    "package:electron": "npm run build && electron-forge package",
    "check": "node --check src/app.js && node --check src/game-engine.js && node --check src/battle-fx.js && node --check src/death-animation.js && node --check src/pixel-art.js && node --check src/combat-animation.js && node --check src/splash.js",
    "test": "npm run check && node --test tests/*.test.js"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "concurrently": "^10.0.3",
    "electron": "^43.1.0",
    "vite": "^8.1.4",
    "wait-on": "^9.0.10"
  }
}
